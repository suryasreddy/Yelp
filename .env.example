# Copy to `.env` for Docker Compose. Keys match `k8s/configmap.yaml` and `k8s/secrets.example.yaml` (EKS).
# `backend/config.py` maps JWT_SECRET → signing key, JWT_ALGORITHM → ALGORITHM, SESSION_EXPIRE_MINUTES → token TTL.

MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=yelp_lab2
JWT_SECRET=change-me-lab2
JWT_ALGORITHM=HS256
SESSION_EXPIRE_MINUTES=1440
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=yelp-lab2
# Set true only for JMeter / load testing (allows same user to queue multiple reviews for one restaurant).
ALLOW_DUPLICATE_REVIEW_SUBMITS=false

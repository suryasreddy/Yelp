# Lab 2 Part 1.1 — Restaurant Owner Service (same FastAPI app; owner routes included)
FROM python:3.11-slim

LABEL org.opencontainers.image.title="yelp-restaurant-owner-service"
LABEL com.yelp.lab2.service="restaurant-owner"

WORKDIR /app

COPY backend/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY backend /app

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]

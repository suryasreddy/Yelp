# Lab 2 Part 1.1 — Review Service (Kafka consumer / worker; persists reviews from events)
FROM python:3.11-slim

LABEL org.opencontainers.image.title="yelp-review-service"
LABEL com.yelp.lab2.service="review-worker"

WORKDIR /app

COPY backend/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY backend /app

CMD ["python", "review_worker.py"]
